APP_NAME="Mentra-AI"
APP_VERSION=0.1

GEMINI_API_KEY=
COHERE_API_KEY=

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT="Mentra-ai"

TAVILY_API_KEY=...
YOUTUBE_API_KEY=...

# Chatbot
# Avaliable OPTIONS TYPES ["GEMINI","OPENAI","COHERE"]
ROUTER_LLM_TYPE="GEMINI"
ROUTER_LLM_MODEL="gemma-3-27b-it"

SIMPLE_LLM_TYPE="GEMINI"
SIMPLE_LLM_MODEL="gemma-3-27b-it"

MEDIUM_LLM_TYPE="GEMINI"
MEDIUM_LLM_MODEL="gemini-2.5-flash-lite"

ADVANCED_LLM_TYPE="GEMINI"
ADVANCED_LLM_MODEL="gemini-2.5-flash"

# Embeddings
EMBEDDING_MODEL_TYPE="COHERE"
EMBEDDING_MODEL_NAME="embed-multilingual-v3.0"
EMBEDDING_SIZE=1024

# Chat Window
MEMORY_MAX_WINDOW=20
MEMORY_SUMMARY_INTERVAL=5

# Redis Conf
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_SECONDS=86400
# ========================
