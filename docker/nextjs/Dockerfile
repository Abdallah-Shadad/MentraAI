# =============================================================
# Stage 1 — DEPS
# Install production + dev dependencies needed for the build.
# Cached separately so npm ci only re-runs when package-lock changes.
# =============================================================
FROM node:22.18.0-alpine AS deps

WORKDIR /app

# Install libc compat for alpine + sharp (image optimisation)
RUN apk add --no-cache libc6-compat

COPY Frontend/package.json Frontend/package-lock.json ./

# Clean install — exact versions, no surprises in production
RUN npm ci

# =============================================================
# Stage 2 — BUILDER
# Runs next build with the full node_modules from Stage 1.
# NEXT_PUBLIC_* vars must be injected here — they are baked into
# the browser bundle at build time, not available at runtime.
# =============================================================
FROM node:22-alpine AS builder

WORKDIR /app

# Receive build-time env vars from docker-compose build.args
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

COPY --from=deps /app/node_modules ./node_modules
COPY Frontend/ .

RUN npm run build

# =============================================================
# Stage 3 — RUNNER
# Uses only the standalone output — no node_modules, no source.
# next.config.mjs must have output: 'standalone' for this to work.
# Final image is ~100MB vs ~600MB full install.
# =============================================================
FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
# PORT is read by Next.js standalone server.js
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Create a non-root user for security (same pattern as official Next.js docs)
RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 nextjs

# Copy only what the standalone server needs
COPY --from=builder --chown=nextjs:nodejs /app/public            ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone  ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static      ./.next/static

USER nextjs

EXPOSE 3000

# server.js is generated by Next.js standalone output
CMD ["node", "server.js"]
