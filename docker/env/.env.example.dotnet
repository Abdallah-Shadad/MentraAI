# =============================================================
# MentraAI .NET API — Environment Variables
# Used by the 'dotnet_api' service only.
#
# PostgreSQL credentials are in ./env/.env.postgres
#
# Copy this file to .env.dotnet and fill in the secrets.
# NEVER commit .env.dotnet to version control.
# =============================================================

# ------ entrypoint.sh — pg_isready waiter ------
# Must match POSTGRES_USER in .env.postgres
# DB_HOST must match the docker-compose service name
DB_HOST=postgres
DB_USER=postgres

# ------ EF Core Connection String ------
# ASP.NET Core maps __ → : so this resolves to ConnectionStrings:DefaultConnection
# Password must match POSTGRES_PASSWORD in .env.postgres
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=mentra_db;Username=postgres;Password=Change_Me_Strong_Password_123

# ------ JWT ------
# SecretKey must be at least 32 characters for HS256
Jwt__SecretKey=Change_Me_Your_Super_Secret_JWT_Key_Min32Chars
Jwt__Issuer=MentraAI
Jwt__Audience=MentraAI-Users
Jwt__AccessTokenExpiryMinutes=15
Jwt__RefreshTokenExpiryDays=7

# ------ AI Service ------
# Points to FastAPI service name inside the Docker backend network
AIService__BaseUrl=http://fastapi:8000

# ------ CORS ------
# Comma-separated list of allowed origins
# For production replace with your actual frontend domain(s)
Cors__AllowedOrigins=http://localhost:3000

# ------ ASP.NET Core Runtime ------
ASPNETCORE_ENVIRONMENT=Production
PORT=8080

# ------ OAuth Authentication ------
# ASP.NET Core maps double underscores (__) to colons (:)
Authentication__Google__ClientId=YOUR_GOOGLE_CLIENT_ID
Authentication__GitHub__ClientId=YOUR_GITHUB_CLIENT_ID
Authentication__GitHub__ClientSecret=YOUR_GITHUB_CLIENT_SECRET
Authentication__Apple__ClientId=YOUR_APPLE_CLIENT_ID
