# =============================================================
# Next.js — Environment Variables
# Used by the 'nextjs' service in docker-compose.yml.
#
# IMPORTANT: NEXT_PUBLIC_* variables are baked into the browser
# bundle at BUILD TIME via docker-compose build.args.
# Changing them requires a full image rebuild (docker compose up --build).
#
# Copy this file to .env.nextjs and set your values.
# NEVER commit .env.nextjs to version control.
# =============================================================

# ------ API Base URL (baked at build time) ------
# Browser-side Axios calls go to this URL.
# In Docker: traffic hits nginx → nginx routes /api/ → dotnet_api:8080
# For local testing: http://localhost/api
# For production:    https://yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost/api

# ------ Runtime vars ------
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
