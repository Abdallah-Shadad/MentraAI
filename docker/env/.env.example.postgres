# =============================================================
# PostgreSQL Service — Environment Variables
# Read by the official postgres:17-alpine image on first startup.
#
# Copy this file to .env.postgres and fill in your credentials.
# NEVER commit .env.postgres to version control.
# =============================================================

# Superuser credentials — created automatically on first run
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Change_Me_Strong_Password_123
POSTGRES_DB=mentra_db
